# PostgreSQL container configuration
# These are used by BOTH the docker container AND the Spring Boot app
POSTGRES_DB=bossbot
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres

# Spring Boot database URL for LOCAL development (native PostgreSQL on localhost:5432)
# Username and password are taken from POSTGRES_USER/POSTGRES_PASSWORD above

SPRING_DATASOURCE_URL=jdbc:postgresql://localhost:5432/bossbot

# Note: When using Docker Compose, the SPRING_DATASOURCE_URL is overridden
# in docker-compose.yaml to use 'postgres' as the hostname instead of 'localhost'

# Google OAuth2
GOOGLE_CLIENT_ID=<YOUR GOOGLE CLIENT ID>
GOOGLE_CLIENT_SECRET=<YOUR GOOGLE CLIENT SECRET>

# JWT
JWT_SECRET=<GENERATE AND ADD HERE JWT SECRET>

# CORS:
APP_CORS_ALLOWED_ORIGINS=http://localhost:5173

OPENAI_API_KEY=sk-your-key-here

OPENAI_MODEL=gpt-4o-mini
OPENAI_MAX_TOKENS=1024
OPENAI_TEMPERATURE=0.7

# Ollama (optional — local LLM for embeddings and chat)
# Docker Compose handles this automatically
OLLAMA_ENABLED=false
OLLAMA_URL=http://localhost:11434
OLLAMA_MODEL=nomic-embed-text
OLLAMA_CHAT_MODEL=llama3.2:3b

# Stamp Answer Matching Configuration
STAMP_MATCHER_SIMILARITY_THRESHOLD=0.7
STAMP_MATCHER_KEYWORD_THRESHOLD=0.3
STAMP_MATCHER_MIN_INPUT_LENGTH=3
